{
  "name": "bpmn-svg-generator",
  "version": "0.1.2",
  "description": "Reusable BPMN-to-SVG generator for Kogito-compatible process SVG assets.",
  "type": "module",
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "bpmn-svg": "bin/bpmn-svg.js"
  },
  "scripts": {
    "test": "node --test",
    "generate": "node ./bin/bpmn-svg.js generate",
    "verify": "node ./bin/bpmn-svg.js verify",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "bpmn",
    "svg",
    "kogito",
    "kie"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karthikeyanga/bpmn-svg-generator.git"
  },
  "bugs": {
    "url": "https://github.com/karthikeyanga/bpmn-svg-generator/issues"
  },
  "homepage": "https://github.com/karthikeyanga/bpmn-svg-generator#readme",
  "dependencies": {
    "@kie-tools/kie-editors-standalone": "^10.1.0",
    "fast-xml-parser": "^5.3.0",
    "playwright": "^1.54.2"
  },
  "engines": {
    "node": ">=20"
  }
}
